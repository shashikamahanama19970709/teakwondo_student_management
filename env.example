# Environment Configuration for Help Line Academy
# Copy this file to .env and update the values for your deployment

# ===========================================
# Database Configuration
# ===========================================
# Database credentials are configured through the setup wizard UI
# No database credentials needed in environment variables

# ===========================================
# Authentication Secrets
# ===========================================
# Generate secure random strings for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this-in-production

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ===========================================
# Redis Configuration
# ===========================================
# For Docker deployment, use internal service name
REDIS_URL=redis://redis:6379

# ===========================================
# Backblaze B2 Configuration
# ===========================================
# Required for file uploads and storage
B2_KEY_ID='005b53028d1c0a80000000001'
B2_APP_KEY='K005SWf+JfJ6feoZyJl1YC12mgUbifM'
B2_BUCKET_ID='fba53340a2f82d019cd00a18'
B2_BUCKET_NAME='Taekwondo'
B2_S3_ENDPOINT='https://s3.us-east-005.backblazeb2.com'
B2_S3_BUCKET='Taekwondo'
B2_S3_KEY_ID='005b53028d1c0a80000000002'
B2_S3_APPLICATION_KEY='K005HNjWoMnRjDuMNo+6xaNV8KJYJiI'

# Backblaze S3-Compatible Configuration (for large direct uploads)
# Use the values from your "my-app-s3-upload-key" and bucket settings
B2_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_S3_BUCKET=Taekwondo
B2_S3_KEY_ID=your-s3-key-id-here
B2_S3_APPLICATION_KEY=your-s3-application-key-here
B2_S3_ENDPOINT='https://s3.us-east-005.backblazeb2.com'
B2_S3_BUCKET='Taekwondo'
B2_S3_KEY_ID='005b53028d1c0a80000000002'
B2_S3_APPLICATION_KEY='K005HNjWoMnRjDuMNo+6xaNV8KJYJiI'

# ===========================================
# Public (client-exposed) Configuration
# ===========================================
# Exposed to the browser; safe for non-secrets
NEXT_PUBLIC_APP_VERSION=0.0.1
# Optionally set by CI to display commit SHA when version not provided
NEXT_PUBLIC_GIT_COMMIT_SHA=
# Application URL for invitation links and other absolute URLs
# If not set, will be automatically detected from request headers
# NEXT_PUBLIC_APP_URL=https://your-domain.com
